127.0.0.1:80 {
    handle /api/* {
        reverse_proxy django:8000
    }

    handle /admin/* {
        reverse_proxy django:8000
    }

    handle /media/* {
        uri strip_prefix /media
        root * /srv/media
        file_server
    }

    handle {
        root * /srv/static
        file_server
    }
}
